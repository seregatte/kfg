}

# Internal kfg execution helper - executes kfg subprocesses with quiet logging
# This helper forces KFG_VERBOSE=0 for the child process without mutating parent environment
# Usage: __kfg_internal <kfg-args...>
# Example:
#   __kfg_internal sys cache exists "$step_ref_name"
#   __kfg_internal apply -k "$overlay"
__kfg_internal() {
    KFG_VERBOSE=0 kfg "$@"
}
