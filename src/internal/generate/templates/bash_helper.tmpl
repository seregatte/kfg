# Internal context management

__kfg_ctx_reset() {
    declare -gA __kfg_outputs=()
}

__kfg_output_set() {
    local step="$1"
    local name="$2"
    local value="$3"
    __kfg_outputs["${step}.${name}"]="$value"
}

__kfg_output_get() {
    local step="$1"
    local name="$2"
    printf '%s' "${__kfg_outputs["${step}.${name}"]:-}"
}

# Cache helpers

# Compute cache identity for a step invocation
# Args: step_ref_name
# Returns: cache entry path (printed to stdout)
__kfg_cache_identity() {
    local step_ref_name="$1"
    
    # Compute unique cache key from step reference name
    local identity_hash
    identity_hash=$(printf '%s' "$step_ref_name" | sha256sum | cut -d' ' -f1)
    
    # Return cache entry path under KFG_STORE_DIR/cache/
    local store_dir="${KFG_STORE_DIR:-${HOME}/.kfg/store}"
    printf '%s/cache/%s' "$store_dir" "$identity_hash"
}

# Check if cache entry exists
# Args: cache_path
# Returns: 0 if exists, 1 if not
__kfg_cache_exists() {
    local cache_path="$1"
    [ -d "$cache_path" ] && [ -f "$cache_path/metadata.yaml" ]
}

# Store artifacts and outputs for a cacheable step
# Args: cache_path, step_ref_name, output_name (optional), step_artifacts_array_name, decl_artifacts_array_name
# The array names are passed by reference and expanded within this function
# Uses atomic write: writes to .tmp directory then renames to final path
__kfg_cache_store() {
    local cache_path="$1"
    local step_ref_name="$2"
    local output_name="$3"
    local step_artifacts_array_name="$4"  # Name of the array variable (passed as string)
    local decl_artifacts_array_name="$5"   # Name of the array variable (passed as string)
    
    # Remove any stale temp directory from previous interrupted write
    rm -rf "$cache_path.tmp"
    
    # Create temp directory for atomic write
    mkdir -p "$cache_path.tmp/artifacts"
    
    # Expand the arrays by name
    local -a step_artifacts=()
    local -a decl_artifacts=()
    eval "step_artifacts=(\"\${${step_artifacts_array_name}[@]}\")"
    eval "decl_artifacts=(\"\${${decl_artifacts_array_name}[@]}\")"
    
    # Combine step artifacts (runtime delta) with declarative artifacts
    local -a all_artifacts=()
    all_artifacts=("${step_artifacts[@]}" "${decl_artifacts[@]}")
    
    # Remove duplicates while preserving order
    local -a unique_artifacts=()
    local seen_art
    declare -A seen_arts=()
    for seen_art in "${all_artifacts[@]}"; do
        if [ -z "${seen_arts[$seen_art]}" ]; then
            unique_artifacts+=("$seen_art")
            seen_arts[$seen_art]=1
        fi
    done
    
    # Store artifacts with their original relative paths
    local artifact
    for artifact in "${unique_artifacts[@]}"; do
        if [ -e "$artifact" ]; then
            # Preserve the full relative path in the cache
            # Create parent directories in the cache to match the artifact's path
            local artifact_dir
            artifact_dir=$(dirname "$artifact")
            if [ "$artifact_dir" != "." ] && [ -n "$artifact_dir" ]; then
                mkdir -p "$cache_path.tmp/artifacts/$artifact_dir"
            fi
            
            # Copy artifact preserving its relative path structure
            __kfg_log_debug "cache" "Storing artifact: $artifact"
            cp -r "$artifact" "$cache_path.tmp/artifacts/$artifact" 2>/dev/null || true
        fi
    done
    
    # Store metadata using echo-based line-by-line construction (no printf '%b' to avoid backslash interpretation)
    {
        echo "stepRefName: ${step_ref_name}"
        echo "timestamp: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
        if [ -n "$output_name" ]; then
            # Serialize output value using base64 for multiline safety
            local output_value
            output_value=$(__kfg_output_get "$step_ref_name" "$output_name")
            local output_encoded
            output_encoded=$(printf '%s' "$output_value" | base64)
            echo "output:"
            echo "  name: ${output_name}"
            # Use YAML literal block scalar for multi-line base64
            # This ensures YAML parsers can read multi-line values correctly
            echo '  valueEncoded: |'
            # Indent each line of base64 output by 4 spaces for block scalar
            echo "$output_encoded" | sed 's/^/    /'
        fi
        # Write artifacts as YAML list
        if [ ${#unique_artifacts[@]} -gt 0 ]; then
            echo "artifacts:"
            for artifact in "${unique_artifacts[@]}"; do
                echo "  - ${artifact}"
            done
        fi
    } > "$cache_path.tmp/metadata.yaml"
    
    # Atomically rename temp directory to final cache path
    mv "$cache_path.tmp" "$cache_path"
}

# Restore artifacts and outputs from cache
# Args: cache_path, step_ref_name, output_name (optional), decl_artifacts_array_name
# decl_artifacts_array_name is the name of the declarative artifacts array to register after restore
# Reads artifacts from metadata.yaml with artifact_paths.txt fallback for legacy entries
__kfg_cache_restore() {
    local cache_path="$1"
    local step_ref_name="$2"
    local output_name="$3"
    local decl_artifacts_array_name="$4"  # Name of the array variable (passed as string)
    
    # Expand the declarative artifacts array by name
    local -a decl_artifacts=()
    eval "decl_artifacts=(\"\${${decl_artifacts_array_name}[@]}\")"
    
    # Read stored artifact paths from metadata.yaml or fallback to artifact_paths.txt
    local -a stored_artifacts=()
    
    # Try reading from metadata.yaml first (new format)
    if [ -f "$cache_path/metadata.yaml" ] && grep -q "^artifacts:" "$cache_path/metadata.yaml"; then
        # Parse YAML artifacts list
        while IFS= read -r line; do
            # Extract artifact path from YAML list item "  - path"
            if [[ "$line" =~ ^\s+-\s+(.+)$ ]]; then
                local artifact_path="${BASH_REMATCH[1]}"
                [ -n "$artifact_path" ] && stored_artifacts+=("$artifact_path")
            fi
        done < "$cache_path/metadata.yaml"
    elif [ -f "$cache_path/artifact_paths.txt" ]; then
        # Fallback: read from legacy artifact_paths.txt
        while IFS= read -r artifact_path; do
            [ -n "$artifact_path" ] && stored_artifacts+=("$artifact_path")
        done < "$cache_path/artifact_paths.txt"
    fi
    
    # Restore each artifact to its original relative path
    local artifact_path
    for artifact_path in "${stored_artifacts[@]}"; do
        if [ -e "$cache_path/artifacts/$artifact_path" ]; then
            # Recreate parent directories if needed
            local artifact_dir
            artifact_dir=$(dirname "$artifact_path")
            if [ "$artifact_dir" != "." ] && [ -n "$artifact_dir" ]; then
                mkdir -p "$artifact_dir"
            fi
            
            # Copy artifact to its original relative path
            __kfg_log_debug "cache" "Restoring artifact: $artifact_path"
            cp -r "$cache_path/artifacts/$artifact_path" "$artifact_path" 2>/dev/null || true
            
            # Register artifact in KFG_ARTIFACTS
            __kfg_add_artifact "$artifact_path"
        fi
    done
    
    # Register declarative artifacts that weren't stored in cache
    # These are artifacts that were declared but not actually produced
    local decl_art
    for decl_art in "${decl_artifacts[@]}"; do
        # Check if it's already registered (from cache restore)
        local already_registered=0
        local check_art
        for check_art in "${KFG_ARTIFACTS[@]}"; do
            if [ "$check_art" = "$decl_art" ]; then
                already_registered=1
                break
            fi
        done
        
        # If not already registered, register it now
        if [ $already_registered -eq 0 ] && [ -e "$decl_art" ]; then
            __kfg_log_debug "cache" "Registering declarative artifact: $decl_art"
            __kfg_add_artifact "$decl_art"
        fi
    done
    
    # Restore output if metadata contains it
    if [ -f "$cache_path/metadata.yaml" ] && [ -n "$output_name" ]; then
        # Parse encoded output value from metadata
        # Support both block scalar format (new) and inline format (legacy)
        local output_encoded
        if grep -q 'valueEncoded: |' "$cache_path/metadata.yaml"; then
            # Block scalar format: extract indented lines after 'valueEncoded: |'
            # Use awk for portability across BSD (macOS) and GNU (Linux) systems
            output_encoded=$(awk '
/^  valueEncoded: \|/ { found=1; next }
found && /^    / { print substr($0, 5) }
found && !/^    / { exit }
' "$cache_path/metadata.yaml")
        else
            # Legacy inline format: grep and cut
            output_encoded=$(grep 'valueEncoded:' "$cache_path/metadata.yaml" | cut -d' ' -f2 || true)
        fi
        if [ -n "$output_encoded" ]; then
            local output_value
            output_value=$(printf '%s' "$output_encoded" | base64 -d)
            __kfg_output_set "$step_ref_name" "$output_name" "$output_value"
        fi
    fi
}

# When condition evaluation

__kfg_when_equals() {
    local step="$1"
    local name="$2"
    local expected="$3"
    local actual="$(__kfg_output_get "$step" "$name")"
    [ "$actual" = "$expected" ]
}

__kfg_when_in() {
    local step="$1"
    local name="$2"
    local actual="$(__kfg_output_get "$step" "$name")"
    shift 2
    for expected in "$@"; do
        [ "$actual" = "$expected" ] && return 0
    done
    return 1
}

__kfg_when_contains() {
    local step="$1"
    local name="$2"
    local substring="$3"
    local actual="$(__kfg_output_get "$step" "$name")"
    [ -z "$actual" ] && return 1
    [[ "$actual" == *"$substring"* ]]
}

__kfg_when_matches() {
    local step="$1"
    local name="$2"
    local pattern="$3"
    local actual="$(__kfg_output_get "$step" "$name")"
    [ -z "$actual" ] && return 1
    [[ "$actual" =~ $pattern ]]
}

__kfg_when_allof() {
    for cond in "$@"; do
        eval "$cond" || return 1
    done
    return 0
}

__kfg_when_anyof() {
    for cond in "$@"; do
        eval "$cond" && return 0
    done
    return 1
}

__kfg_when_not() {
    local cond="$1"
    eval "$cond" && return 1
    return 0
}

# Logging helpers - delegate to kfg sys log subcommand
# These helpers produce identical output to the Go logger.
# Usage: __kfg_log_<level> [component] <message>
#   - If 1 argument: treat as message, use component="step"
#   - If 2+ arguments: first is component, rest is message
# Usage errors are written directly to stderr to avoid recursion.

__kfg_log_error() {
    local component message
    if [ $# -eq 1 ]; then
        component="step"
        message="$1"
    elif [ $# -ge 2 ]; then
        component="$1"
        message="$2"
    else
        echo "Usage: __kfg_log_error [component] <message>" >&2
        return 1
    fi
    kfg sys log error "$component" "$message"
}

__kfg_log_warn() {
    local component message
    if [ $# -eq 1 ]; then
        component="step"
        message="$1"
    elif [ $# -ge 2 ]; then
        component="$1"
        message="$2"
    else
        echo "Usage: __kfg_log_warn [component] <message>" >&2
        return 1
    fi
    kfg sys log warn "$component" "$message"
}

__kfg_log_info() {
    local component message
    if [ $# -eq 1 ]; then
        component="step"
        message="$1"
    elif [ $# -ge 2 ]; then
        component="$1"
        message="$2"
    else
        echo "Usage: __kfg_log_info [component] <message>" >&2
        return 1
    fi
    kfg sys log info "$component" "$message"
}

__kfg_log_detail() {
    local component message
    if [ $# -eq 1 ]; then
        component="step"
        message="$1"
    elif [ $# -ge 2 ]; then
        component="$1"
        message="$2"
    else
        echo "Usage: __kfg_log_detail [component] <message>" >&2
        return 1
    fi
    kfg sys log detail "$component" "$message"
}

__kfg_log_debug() {
    local component message
    if [ $# -eq 1 ]; then
        component="step"
        message="$1"
    elif [ $# -ge 2 ]; then
        component="$1"
        message="$2"
    else
        echo "Usage: __kfg_log_debug [component] <message>" >&2
        return 1
    fi
    kfg sys log debug "$component" "$message"
}

# Filesystem helpers - delegate to kfg sys fs subcommands
# These helpers provide portable filesystem inspection for Steps.

# Internal kfg execution helper - executes kfg subprocesses with quiet logging
# This helper forces KFG_VERBOSE=0 for the child process without mutating parent environment
# Usage: __kfg_internal <kfg-args...>
# Example:
#   output=$(__kfg_internal sys fs snapshot "$dir")
#   __kfg_internal apply -k "$overlay"
__kfg_internal() {
    KFG_VERBOSE=0 kfg "$@"
}

# Snapshot filesystem paths under a directory
# Args: path [maxdepth]
# Returns: normalized relative paths (one per line) to stdout
# Usage: __kfg_fs_snapshot <path> [<maxdepth>]
#   - path: directory to snapshot
#   - maxdepth: optional depth limit (0 = unlimited, default 0)
# Example:
#   paths=$(__kfg_fs_snapshot "$OUTPUT_DIR" 1)
__kfg_fs_snapshot() {
    local path="$1"
    local maxdepth="${2:-0}"  # Default to unlimited depth
    
    __kfg_internal sys fs snapshot "$path" --maxdepth "$maxdepth"
}

# Diff two filesystem snapshots
# Args: before_snapshot_file after_snapshot_file
# Returns: paths newly present in after (one per line) to stdout
# Usage: __kfg_fs_diff <before_file> <after_file>
# Example:
#   new_paths=$(__kfg_fs_diff before.txt after.txt)
__kfg_fs_diff() {
    local before_file="$1"
    local after_file="$2"
    
    __kfg_internal sys fs diff --before "$before_file" --after "$after_file"
}
# Register artifacts from snapshot diff under a root directory
# Args: root before_snapshot_file after_snapshot_file
# Returns: registers each diff path prefixed with root via __kfg_add_artifact
# Usage: __kfg_add_diff_artifacts <root> <before_file> <after_file>
#   - root: the snapshot root directory to prefix onto relative diff paths
#   - before_file: snapshot file from before state
#   - after_file: snapshot file from after state
# Example:
#   __kfg_add_diff_artifacts "$OUTPUT_DIR" before.txt after.txt
__kfg_add_diff_artifacts() {
    local root="$1"
    local before_file="$2"
    local after_file="$3"
    
    # Get diff paths (relative to snapshot root)
    local diff_paths
    diff_paths=$(__kfg_fs_diff "$before_file" "$after_file")
    
    # Process each diff path
    local rel_path
    while IFS= read -r rel_path; do
        [ -z "$rel_path" ] && continue
        
        # Construct full path by prefixing root
        # Normalize to avoid double slashes (remove trailing slash from root, leading slash from rel_path)
        local full_path="${root%%/}/${rel_path#/}"
        
        # Verify existence before registering
        if [ -e "$full_path" ]; then
            __kfg_add_artifact "$full_path"
        fi
    done <<< "$diff_paths"
}
